@startuml use-case
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle

actor Teacher
actor Student

rectangle "SmartGrader" {
  usecase "Create Exam" as UC1
  usecase "Add Questions" as UC2
  usecase "Generate Answer Sheet" as UC3
  usecase "Scan MCQ Sheet" as UC4
  usecase "AI Grade Short Answers" as UC5
  usecase "View Results" as UC6
  usecase "Manage Students" as UC7
  usecase "Review & Correct AI Grades" as UC8
  usecase "Take Exam" as UC9
}

Teacher --> UC1
Teacher --> UC2
Teacher --> UC3
Teacher --> UC4
Teacher --> UC5
Teacher --> UC6
Teacher --> UC7
Teacher --> UC8

Student --> UC9

UC2 ..> UC1 : <<include>>
UC4 ..> UC3 : <<include>>
UC8 ..> UC5 : <<extend>>
@enduml
